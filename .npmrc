# IAFS — npm config
#
# package-lock=false: we don't track a lockfile.
# Reason: npm/cli#4828 means a macOS-generated lockfile omits Linux native
# binaries (e.g. @rollup/rollup-linux-x64-gnu), which then break Linux
# builds (GitHub Actions, Cloudflare Pages). Removing the lockfile forces
# fresh platform-aware resolution on every install.
#
# Reproducibility tradeoff is acceptable for a project of this size and
# dep stability. Major version pins live in package.json.
package-lock=false
