---
import "@site/styles/global.css";
import { t, otherLocale, localePath, type Locale } from "@site/lib/i18n";
import { getMethodology } from "@site/lib/data";

interface Props { locale: Locale; title: string; pagePath: string; }
const { locale, title, pagePath } = Astro.props;
const other = otherLocale(locale);
const methodology = getMethodology();
const isDummy = methodology.mode === "dummy";
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="dark" />
    <meta name="theme-color" content="#0A0B10" />
    <title>{title} — {t(locale, "site_title")}</title>
    <meta name="description" content={t(locale, "site_subtitle")} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet"
          href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500;600&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" />
  </head>
  <body class="min-h-screen flex flex-col bg-bg text-text">
    <a href="#main" class="skip-link">{locale === "fr" ? "Aller au contenu" : "Skip to content"}</a>

    {isDummy && (
      <div role="status" class="bg-accent/15 border-b border-accent/30 text-text text-center text-xs py-2 px-3 font-mono">
        <span class="text-accent font-medium uppercase tracking-wider mr-2">●</span>
        {t(locale, "dummy_banner")}
      </div>
    )}

    <header class="border-b border-border bg-bg/95 backdrop-blur sticky top-0 z-30">
      <div class="max-w-page mx-auto px-4 lg:px-6 py-4 flex items-center justify-between gap-4 flex-wrap">
        <a href={localePath(locale, "/")} class="flex flex-col leading-tight group">
          <span class="font-serif text-lg group-hover:text-axisA transition-colors">{t(locale, "site_title")}</span>
          <span class="text-xs text-dim hidden sm:block">{t(locale, "site_subtitle")}</span>
        </a>
        <nav aria-label="primary" class="flex flex-wrap items-center gap-1 text-sm">
          {[
            { href: "/",            label: t(locale, "nav.map") },
            { href: "/plot",        label: t(locale, "nav.plot") },
            { href: "/countries",   label: t(locale, "nav.countries") },
            { href: "/events",      label: t(locale, "nav.events") },
            { href: "/methodology", label: t(locale, "nav.methodology") },
            { href: "/download",    label: t(locale, "nav.download") },
          ].map((item) => (
            <a href={localePath(locale, item.href)}
               class="px-3 py-1.5 rounded-md text-muted hover:text-text hover:bg-surface transition-colors">
              {item.label}
            </a>
          ))}
          <a href={localePath(other, pagePath)}
             aria-label={t(locale, "lang_switch_label")}
             class="ml-2 font-mono text-xs border border-border px-3 py-1.5 rounded-md text-muted hover:text-text hover:border-text transition-colors">
            {t(locale, "lang_switch")}
          </a>
        </nav>
      </div>
    </header>

    <main id="main" class="flex-1 max-w-page w-full mx-auto px-4 lg:px-6 py-6">
      <slot />
    </main>

    <footer class="border-t border-border mt-16">
      <div class="max-w-page mx-auto px-4 lg:px-6 py-6 text-xs text-dim flex justify-between flex-wrap gap-2">
        <span>{t(locale, "footer_license")}</span>
        <span class="font-mono">schema v0.3.0 · <span class="text-muted">{t(locale, "two_scores_never_one")}</span></span>
      </div>
    </footer>
  </body>
</html>
