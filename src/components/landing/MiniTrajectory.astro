---
import type { Locale } from "@site/lib/i18n";
import { t, localePath } from "@site/lib/i18n";
import { getTrajectory } from "@site/lib/data";

interface Props {
  locale: Locale;
  iso3: string;
  nameFR: string;
  nameEN: string;
}
const { locale, iso3, nameFR, nameEN } = Astro.props;
const traj = getTrajectory(iso3);
const name = locale === "fr" ? nameFR : nameEN;

const W = 360, H = 100, PAD_L = 8, PAD_R = 8, PAD_T = 12, PAD_B = 20;
const innerW = W - PAD_L - PAD_R;
const innerH = H - PAD_T - PAD_B;
const yearsSpan = traj.current_year - traj.independence_year || 1;
const xFor = (y: number) => PAD_L + ((y - traj.independence_year) / yearsSpan) * innerW;
const yFor = (s: number) => PAD_T + innerH - (s / 100) * innerH;

function pathFor(axis: "axis_a" | "axis_b"): string {
  let d = "";
  let pen = false;
  for (const y of traj.years) {
    const v = y[axis];
    if (v.score === null) { pen = false; continue; }
    d += `${pen ? "L" : "M"}${xFor(y.year).toFixed(1)},${yFor(v.score).toFixed(1)} `;
    pen = true;
  }
  return d.trim();
}

const stepMarkers = traj.years.flatMap((y: any) => y.step_changes.map((s: any) => ({ ...s, year: y.year })));
const baselineTick = xFor(traj.independence_year);
const dummyLabel = locale === "fr" ? "DONNÉES FACTICES" : "DUMMY DATA";
---

<a
  href={localePath(locale, `/country/${iso3}`)}
  class="iafs-mini group block bg-surface border border-border p-4 rounded-md
         hover:border-axisA hover:-translate-y-0.5
         focus-visible:border-axisA
         transition-all duration-200 cursor-pointer h-full"
>
  <div class="flex items-baseline justify-between gap-3 mb-1">
    <h3 class="font-serif text-base group-hover:text-axisA transition-colors">{name}</h3>
    <span class="font-mono text-xs text-accent uppercase tracking-widest">{dummyLabel}</span>
  </div>
  <p class="font-mono text-xs text-dim mb-3">
    {iso3} · {traj.independence_year}—{traj.current_year}
  </p>

  <svg viewBox={`0 0 ${W} ${H}`} class="w-full h-auto" role="img" aria-label={`${name} trajectory ${traj.independence_year}–${traj.current_year}`}>
    <line x1={baselineTick} y1={PAD_T} x2={baselineTick} y2={H - PAD_B} stroke="rgb(255 92 92)" stroke-width="1" stroke-dasharray="2 2" />
    <line x1={PAD_L} y1={yFor(50)} x2={W - PAD_R} y2={yFor(50)} stroke="rgb(160 160 174)" stroke-width="0.5" stroke-dasharray="1 4" opacity="0.4" />

    <path d={pathFor("axis_a")} fill="none" stroke="rgb(107 142 255)" stroke-width="1.75" data-axis="A" />
    <path d={pathFor("axis_b")} fill="none" stroke="rgb(255 185 74)" stroke-width="1.75" data-axis="B" />

    {stepMarkers.map((s) => (
      <line x1={xFor(s.year)} y1={PAD_T - 3} x2={xFor(s.year)} y2={PAD_T + 4}
            stroke={s.axis === "A" ? "rgb(107 142 255)" : "rgb(255 185 74)"} stroke-width="1.5" />
    ))}

    <text x={PAD_L} y={H - 4} font-family="JetBrains Mono, monospace" font-size="10" fill="rgb(107 107 122)">{traj.independence_year}</text>
    <text x={W - PAD_R} y={H - 4} text-anchor="end" font-family="JetBrains Mono, monospace" font-size="10" fill="rgb(107 107 122)">{traj.current_year}</text>
  </svg>

  <div class="flex items-center gap-4 mt-2 text-xs font-mono">
    <span class="axis-A">A · {t(locale, "axis_a").split(" ")[0]}</span>
    <span class="axis-B">B · {t(locale, "axis_b").split(" ")[0]}</span>
    <span class="ml-auto text-dim">{t(locale, "gap_legend")}</span>
  </div>
</a>
