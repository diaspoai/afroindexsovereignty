---
/**
 * Tiny per-country dual-axis sparkline. Pure SVG, no JS.
 * Same gap-honesty rule as the full Scrubber: every null year breaks the
 * path (new M command), no interpolation across gaps.
 */
import type { Locale } from "@site/lib/i18n";
import { t, localePath } from "@site/lib/i18n";
import { getTrajectory } from "@site/lib/data";

interface Props {
  locale: Locale;
  iso3: string;
  nameFR: string;
  nameEN: string;
}
const { locale, iso3, nameFR, nameEN } = Astro.props;
const traj = getTrajectory(iso3);
const name = locale === "fr" ? nameFR : nameEN;

const W = 360, H = 90, PAD_L = 6, PAD_R = 6, PAD_T = 8, PAD_B = 18;
const innerW = W - PAD_L - PAD_R;
const innerH = H - PAD_T - PAD_B;
const yearsSpan = traj.current_year - traj.independence_year || 1;
const xFor = (y: number) => PAD_L + ((y - traj.independence_year) / yearsSpan) * innerW;
const yFor = (s: number) => PAD_T + innerH - (s / 100) * innerH;

function pathFor(axis: "axis_a" | "axis_b"): string {
  let d = "";
  let pen = false;
  for (const y of traj.years) {
    const v = y[axis];
    if (v.score === null) { pen = false; continue; }
    d += `${pen ? "L" : "M"}${xFor(y.year).toFixed(1)},${yFor(v.score).toFixed(1)} `;
    pen = true;
  }
  return d.trim();
}

const stepMarkers = traj.years.flatMap((y: any) => y.step_changes.map((s: any) => ({ ...s, year: y.year })));
const baselineTick = xFor(traj.independence_year);
const dummyLabel = locale === "fr" ? "DONNÉES FACTICES" : "DUMMY DATA";
---

<a
  href={localePath(locale, `/country/${iso3}`)}
  class="iafs-mini block border border-ink/15 p-4 bg-white/60 hover:bg-white hover:border-ink/40 transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ink focus-visible:ring-offset-2 focus-visible:ring-offset-paper cursor-pointer h-full"
>
  <div class="flex items-baseline justify-between gap-3 mb-1">
    <h3 class="font-serif text-lg">{name}</h3>
    <span class="font-mono text-[10px] text-oxblood uppercase tracking-widest">{dummyLabel}</span>
  </div>
  <p class="font-mono text-[10px] text-ink/50 mb-3">
    {iso3} · {traj.independence_year}—{traj.current_year}
  </p>

  <svg viewBox={`0 0 ${W} ${H}`} class="w-full h-auto" role="img" aria-label={`${name} trajectory ${traj.independence_year}–${traj.current_year}`}>
    {/* baseline */}
    <line x1={baselineTick} y1={PAD_T} x2={baselineTick} y2={H - PAD_B} stroke="#6B1E1E" stroke-width="0.75" stroke-dasharray="2 2" />

    {/* gridline at 50 */}
    <line x1={PAD_L} y1={yFor(50)} x2={W - PAD_R} y2={yFor(50)} stroke="#1B1B1F" stroke-width="0.3" stroke-dasharray="1 3" opacity="0.4" />

    {/* axis A path (indigo) */}
    <path d={pathFor("axis_a")} fill="none" stroke="#1F3A93" stroke-width="1.4" data-axis="A" />
    {/* axis B path (ochre) */}
    <path d={pathFor("axis_b")} fill="none" stroke="#B8860B" stroke-width="1.4" data-axis="B" />

    {/* step markers */}
    {stepMarkers.map((s) => (
      <line x1={xFor(s.year)} y1={PAD_T - 2} x2={xFor(s.year)} y2={PAD_T + 4}
            stroke={s.axis === "A" ? "#1F3A93" : "#B8860B"} stroke-width="1.5" />
    ))}

    {/* year labels */}
    <text x={PAD_L} y={H - 4} font-family="JetBrains Mono, monospace" font-size="9" fill="#1B1B1F" opacity="0.5">{traj.independence_year}</text>
    <text x={W - PAD_R} y={H - 4} text-anchor="end" font-family="JetBrains Mono, monospace" font-size="9" fill="#1B1B1F" opacity="0.5">{traj.current_year}</text>
  </svg>

  <div class="flex items-center gap-4 mt-2 text-[11px] font-mono">
    <span class="axis-A">A · {t(locale, "axis_a").split(" ")[0]}</span>
    <span class="axis-B">B · {t(locale, "axis_b").split(" ")[0]}</span>
    <span class="ml-auto text-ink/40">{t(locale, "gap_legend")}</span>
  </div>
</a>
