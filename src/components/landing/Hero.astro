---
import AfricaMap from "./AfricaMap.astro";
import { t, type Locale, localePath } from "@site/lib/i18n";

interface Props { locale: Locale; }
const { locale } = Astro.props;

const headlineFR = ["Deux scores.", "Jamais un."];
const headlineEN = ["Two scores.", "Never one."];
const headline   = locale === "fr" ? headlineFR : headlineEN;
---

<section class="iafs-hero pt-6 pb-12 lg:pb-16">
  {/* Headline strip ABOVE the map — eye-leading, fast read */}
  <header class="max-w-page mx-auto mb-6 lg:mb-8 flex flex-col gap-3">
    <p class="font-mono text-xs uppercase tracking-[0.25em] text-accent">
      {t(locale, "landing.hero.kicker")}
    </p>

    <h1 class="font-serif text-display max-w-[18ch]">
      <span class="block axis-A">{headline[0]}</span>
      <span class="block axis-B">{headline[1]}</span>
    </h1>

    <p class="text-base text-muted max-w-prose leading-snug">
      {t(locale, "landing.hero.lede")}
    </p>
  </header>

  {/* The map — full container width, dominant */}
  <div class="max-w-page mx-auto">
    <AfricaMap locale={locale} />
  </div>

  {/* CTAs + axis legend BELOW the map */}
  <footer class="max-w-page mx-auto mt-8 flex flex-col gap-6">
    <div class="flex flex-wrap gap-3">
      <a href={localePath(locale, "/country/ZZA")}
         class="iafs-cta-primary inline-flex items-center gap-2 bg-text text-bg px-6 py-3 font-mono text-sm uppercase tracking-wider rounded-md hover:bg-axisA hover:text-text active:scale-[0.98] transition-all cursor-pointer">
        {t(locale, "landing.hero.cta_explore")}
        <svg width="14" height="14" viewBox="0 0 14 14" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M2 7h10M8 3l4 4-4 4" stroke-linecap="square" stroke-linejoin="miter" />
        </svg>
      </a>
      <a href={localePath(locale, "/methodology")}
         class="inline-flex items-center gap-2 border border-border px-6 py-3 font-mono text-sm uppercase tracking-wider rounded-md text-text hover:border-text hover:bg-surface active:scale-[0.98] transition-all cursor-pointer">
        {t(locale, "landing.hero.cta_methodology")}
      </a>
    </div>

    <dl class="grid grid-cols-1 sm:grid-cols-2 gap-4 max-w-3xl text-sm">
      <div class="border-l-2 border-axisA pl-3">
        <dt class="font-mono uppercase text-xs tracking-widest axis-A">{t(locale, "axis_a")}</dt>
        <dd class="text-muted mt-1">{t(locale, "axis_a_gloss")}</dd>
      </div>
      <div class="border-l-2 border-axisB pl-3">
        <dt class="font-mono uppercase text-xs tracking-widest axis-B">{t(locale, "axis_b")}</dt>
        <dd class="text-muted mt-1">{t(locale, "axis_b_gloss")}</dd>
      </div>
    </dl>
  </footer>
</section>
