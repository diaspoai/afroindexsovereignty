---
import type { Locale } from "@site/lib/i18n";
import { localePath } from "@site/lib/i18n";

interface Props {
  locale: Locale;
  number: string;
  title: string;
  body: string;
  href: string;
  type?: "HARD" | "INTERP";
}
const { locale, number, title, body, href, type } = Astro.props;
---

<a
  href={localePath(locale, href)}
  class="iafs-commitment group relative block bg-surface border border-border p-6 rounded-md
         hover:border-axisA hover:-translate-y-0.5
         focus-visible:border-axisA
         active:translate-y-0
         transition-all duration-200 cursor-pointer h-full"
>
  <span class="absolute top-4 right-4 font-mono text-xs text-dim uppercase tracking-widest">
    {number}
  </span>

  {type && (
    <span class={`absolute top-4 right-14 ${type === "HARD" ? "type-hard" : "type-interp"} text-dim text-xs`}
          aria-label={type === "HARD" ? "HARD indicator family" : "Interpretive indicator family"}></span>
  )}

  <h3 class="font-serif text-lg mb-3 leading-tight pr-16 group-hover:text-axisA transition-colors">
    {title}
  </h3>
  <p class="text-sm text-muted leading-snug max-w-prose mb-4">{body}</p>

  <span class="inline-flex items-center gap-1 font-mono text-xs text-muted group-hover:text-axisA transition-colors">
    {locale === "fr" ? "Lire" : "Read"}
    <svg width="10" height="10" viewBox="0 0 10 10" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="1.5">
      <path d="M1 5h8M6 2l3 3-3 3" stroke-linecap="square" />
    </svg>
  </span>
</a>
