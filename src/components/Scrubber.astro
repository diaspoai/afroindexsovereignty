---
/**
 * R9 — The Sovereignty Scrubber.
 *
 * Hydrated client island. Builds a per-axis SVG trajectory from independence_year
 * to current_year, with:
 *   - A vertical dashed BASELINE line at independence_year, labeled.
 *   - Two paths (Axis A indigo, Axis B ochre). Gap years break the path (M command).
 *   - data-gap and data-coverage attributes on every year marker for eval 08.
 *   - A year scrubber (range input) that highlights the chosen year on both axes
 *     and surfaces the step-changes / coverage for that year.
 *
 * Inputs come from built/trajectory/<ISO3>.json via the parent country page.
 */
import type { Locale } from "@site/lib/i18n";
import { t } from "@site/lib/i18n";

interface Year {
  year: number;
  axis_a: { score: number | null; coverage: number; gap: boolean };
  axis_b: { score: number | null; coverage: number; gap: boolean };
  step_changes: { axis: "A"|"B"; indicator_id: string; from: number | null; to: number; event_ref?: string }[];
  is_baseline: boolean;
}
interface Props {
  locale: Locale;
  iso3: string;
  independence_year: number;
  current_year: number;
  years: Year[];
}
const { locale, iso3, independence_year, current_year, years } = Astro.props;

const W = 900, H = 320, PAD_L = 50, PAD_R = 20, PAD_T = 24, PAD_B = 40;
const innerW = W - PAD_L - PAD_R;
const innerH = H - PAD_T - PAD_B;
const span = current_year - independence_year || 1;
const xFor = (y: number) => PAD_L + ((y - independence_year) / span) * innerW;
const yFor = (s: number) => PAD_T + innerH - (s / 100) * innerH;

function pathFor(axis: "axis_a"|"axis_b"): string {
  let d = "";
  let pen = false;
  for (const y of years) {
    const v = y[axis];
    if (v.score === null) { pen = false; continue; }
    const cmd = pen ? "L" : "M";
    d += `${cmd}${xFor(y.year).toFixed(1)},${yFor(v.score).toFixed(1)} `;
    pen = true;
  }
  return d.trim();
}

const pathA = pathFor("axis_a");
const pathB = pathFor("axis_b");
const steps = years.flatMap((y) => y.step_changes.map((s) => ({ ...s, year: y.year })));
const data = { iso3, independence_year, current_year, years };
---

<section class="space-y-3" data-scrubber data-iso3={iso3}>
  <div class="flex items-baseline justify-between flex-wrap gap-2">
    <h2 class="text-xl font-serif">
      {iso3} · {independence_year}—{current_year}
    </h2>
    <p class="font-mono text-xs uppercase tracking-widest text-oxblood">— {t(locale, "two_scores_never_one")} —</p>
  </div>

  <svg viewBox={`0 0 ${W} ${H}`} class="w-full border border-ink/15 bg-white/40" role="img"
       aria-label={`${iso3} trajectory ${independence_year}-${current_year}`}>
    {/* axes frame */}
    <line x1={PAD_L} y1={PAD_T} x2={PAD_L} y2={H - PAD_B} stroke="#1B1B1F" stroke-width="0.5" />
    <line x1={PAD_L} y1={H - PAD_B} x2={W - PAD_R} y2={H - PAD_B} stroke="#1B1B1F" stroke-width="0.5" />
    {[0, 25, 50, 75, 100].map((v) => (
      <g>
        <line x1={PAD_L - 4} y1={yFor(v)} x2={W - PAD_R} y2={yFor(v)} stroke="#1B1B1F" stroke-width="0.2" stroke-dasharray="2 4" />
        <text x={PAD_L - 8} y={yFor(v) + 3} text-anchor="end" font-size="9" font-family="monospace">{v}</text>
      </g>
    ))}

    {/* baseline marker — the gap thesis made visible */}
    <line class="trajectory-baseline" x1={xFor(independence_year)} y1={PAD_T} x2={xFor(independence_year)} y2={H - PAD_B} />
    <text x={xFor(independence_year) + 4} y={PAD_T + 12} font-size="10" font-family="monospace" fill="#6B1E1E">
      {t(locale, "baseline_label")}
    </text>

    {/* year ticks every 10 years */}
    {Array.from({ length: Math.floor(span / 10) + 1 }, (_, i) => independence_year + i * 10)
      .filter((y) => y <= current_year)
      .map((y) => (
        <g>
          <line x1={xFor(y)} y1={H - PAD_B} x2={xFor(y)} y2={H - PAD_B + 3} stroke="#1B1B1F" stroke-width="0.5" />
          <text x={xFor(y)} y={H - PAD_B + 14} text-anchor="middle" font-size="9" font-family="monospace">{y}</text>
        </g>
      ))}

    {/* trajectory paths */}
    <path d={pathA} fill="none" stroke="#1F3A93" stroke-width="1.5" data-axis="A" />
    <path d={pathB} fill="none" stroke="#B8860B" stroke-width="1.5" data-axis="B" />

    {/* per-year markers (data-gap, data-coverage) — read by eval 08 */}
    {years.map((y) => (
      <g class="year-marker"
         data-year={y.year}
         data-gap-a={y.axis_a.gap ? "true" : "false"}
         data-gap-b={y.axis_b.gap ? "true" : "false"}
         data-coverage-a={y.axis_a.coverage}
         data-coverage-b={y.axis_b.coverage}>
        {y.axis_a.score !== null && (
          <circle cx={xFor(y.year)} cy={yFor(y.axis_a.score)} r="2" fill="#1F3A93" />
        )}
        {y.axis_b.score !== null && (
          <circle cx={xFor(y.year)} cy={yFor(y.axis_b.score)} r="2" fill="#B8860B" />
        )}
      </g>
    ))}

    {/* step-change vertical pips on axis A or B */}
    {steps.map((s) => (
      <line x1={xFor(s.year)} y1={PAD_T - 4} x2={xFor(s.year)} y2={PAD_T - 12}
            stroke={s.axis === "A" ? "#1F3A93" : "#B8860B"} stroke-width="1.5"
            data-step={s.indicator_id} data-event-ref={s.event_ref ?? ""} />
    ))}

    {/* scrubber cursor (updated by client JS) */}
    <line id={`cursor-${iso3}`} x1={xFor(current_year)} y1={PAD_T} x2={xFor(current_year)} y2={H - PAD_B} stroke="#1B1B1F" stroke-width="0.5" opacity="0.4" />
  </svg>

  <div class="flex items-center gap-3 flex-wrap">
    <label class="text-xs font-mono" for={`year-${iso3}`}>year</label>
    <input id={`year-${iso3}`} type="range" min={independence_year} max={current_year} value={current_year}
           class="flex-1 min-w-[200px]" aria-label="year scrubber" />
    <output id={`out-${iso3}`} class="font-mono text-sm">{current_year}</output>
  </div>

  <dl id={`readout-${iso3}`} class="grid grid-cols-2 gap-3 text-sm font-mono">
    <div><dt class="text-xs uppercase axis-A">{t(locale, "axis_a")}</dt><dd data-out="a">—</dd></div>
    <div><dt class="text-xs uppercase axis-B">{t(locale, "axis_b")}</dt><dd data-out="b">—</dd></div>
  </dl>

  <p class="text-xs text-ink/60 max-w-prose">
    <span class="inline-block w-3 h-0.5 bg-ink/30 align-middle mr-1"></span>
    {t(locale, "gap_legend")}.
    <br/>
    {t(locale, "baseline_gloss")}
  </p>

  <script type="application/json" id={`data-${iso3}`} set:html={JSON.stringify(data)}></script>
</section>

<script is:inline>
  (function () {
    const sections = document.querySelectorAll("[data-scrubber]");
    sections.forEach((sec) => {
      const iso3 = sec.getAttribute("data-iso3");
      const data = JSON.parse(document.getElementById("data-" + iso3).textContent);
      const range = document.getElementById("year-" + iso3);
      const out = document.getElementById("out-" + iso3);
      const cursor = document.getElementById("cursor-" + iso3);
      const readoutA = sec.querySelector('[data-out="a"]');
      const readoutB = sec.querySelector('[data-out="b"]');
      const span = data.current_year - data.independence_year || 1;
      const PAD_L = 50, PAD_R = 20, W = 900;
      const innerW = W - PAD_L - PAD_R;
      const xFor = (y) => PAD_L + ((y - data.independence_year) / span) * innerW;
      function fmt(v, gap) { return gap || v === null ? "— (gap)" : Math.round(v) + "  · cov " + Math.round((v.coverage ?? 0) * 100) + "%"; }
      function update(y) {
        out.textContent = String(y);
        cursor.setAttribute("x1", xFor(y));
        cursor.setAttribute("x2", xFor(y));
        const yr = data.years.find((x) => x.year === y);
        if (!yr) return;
        readoutA.textContent = yr.axis_a.gap ? "— (gap)" : Math.round(yr.axis_a.score) + " · cov " + Math.round(yr.axis_a.coverage * 100) + "%";
        readoutB.textContent = yr.axis_b.gap ? "— (gap)" : Math.round(yr.axis_b.score) + " · cov " + Math.round(yr.axis_b.coverage * 100) + "%";
      }
      range.addEventListener("input", (e) => update(parseInt(e.target.value, 10)));
      update(parseInt(range.value, 10));
    });
  })();
</script>
