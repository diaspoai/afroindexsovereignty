---
import Base from "@site/layouts/Base.astro";
import { getIndicators, getMethodology } from "@site/lib/data";
import { t } from "@site/lib/i18n";

const locale = "en" as const;
const indicators = getIndicators();
const m = getMethodology();
---
<Base locale={locale} title={t(locale, "page.methodology_title")} pagePath="/methodology">
  <section class="space-y-8 max-w-prose mx-auto">
    <header class="space-y-2">
      <p class="font-mono text-xs uppercase tracking-[0.25em] text-accent">R6</p>
      <h1 class="font-serif text-2xl">{t(locale, "page.methodology_title")}</h1>
      <p class="text-sm font-mono text-muted">
        version {m.version} · coverage threshold {Math.round(m.coverage_threshold*100)}% · mode {m.mode}
      </p>
      <p class="text-muted">
        See <a href="/docs/IAFS_Requirements_v0.3.md" class="text-axisA hover:underline focus-visible:underline">the spec document</a>.
      </p>
    </header>

    <section class="space-y-3">
      <h2 class="font-serif text-xl axis-A">{t(locale, "axis_a")}</h2>
      <p class="text-muted text-sm">{t(locale, "axis_a_gloss")}</p>
      <div class="overflow-x-auto bg-surface border border-border rounded-md">
        <table class="text-sm w-full">
          <thead><tr class="text-left text-xs uppercase text-muted border-b border-border">
            <th class="py-3 px-3">id</th><th class="py-3 px-3">indicator</th><th class="py-3 px-3">type</th><th class="py-3 px-3">weight</th><th class="py-3 px-3">since</th>
          </tr></thead>
          <tbody>
            {indicators.filter(i => i.axis === "A").map((i) => (
              <tr class="border-b border-border last:border-b-0">
                <td class="font-mono py-2 px-3 axis-A">{i.id}</td>
                <td class="px-3 text-text">{i.name_en}</td>
                <td class="font-mono px-3 text-muted">{i.type}</td>
                <td class="font-mono px-3 text-muted">×{i.weight}</td>
                <td class="font-mono px-3 text-muted">{i.earliest_sourced_year}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <section class="space-y-3">
      <h2 class="font-serif text-xl axis-B">{t(locale, "axis_b")}</h2>
      <p class="text-muted text-sm">{t(locale, "axis_b_gloss")}</p>
      <div class="overflow-x-auto bg-surface border border-border rounded-md">
        <table class="text-sm w-full">
          <thead><tr class="text-left text-xs uppercase text-muted border-b border-border">
            <th class="py-3 px-3">id</th><th class="py-3 px-3">indicator</th><th class="py-3 px-3">type</th><th class="py-3 px-3">weight</th><th class="py-3 px-3">since</th>
          </tr></thead>
          <tbody>
            {indicators.filter(i => i.axis === "B").map((i) => (
              <tr class="border-b border-border last:border-b-0">
                <td class="font-mono py-2 px-3 axis-B">{i.id}</td>
                <td class="px-3 text-text">{i.name_en}</td>
                <td class="font-mono px-3 text-muted">{i.type}</td>
                <td class="font-mono px-3 text-muted">×{i.weight}</td>
                <td class="font-mono px-3 text-muted">{i.earliest_sourced_year}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <p class="text-xs text-dim font-mono">R6 stub.</p>
  </section>
</Base>
