---
import Base from "@site/layouts/Base.astro";
import Scrubber from "@site/components/Scrubber.astro";
import TagBadge from "@site/components/TagBadge.astro";
import { getCountries, getScores, getIndicators, getTrajectory } from "@site/lib/data";
import { t } from "@site/lib/i18n";

export async function getStaticPaths() {
  return getCountries().map((c) => ({ params: { iso3: c.iso3 }, props: { country: c } }));
}

const { country } = Astro.props;
const locale = "en" as const;
const indicators = getIndicators();
const scores = getScores(country.iso3);
const traj = getTrajectory(country.iso3);
---

<Base locale={locale} title={country.name_en} pagePath={`/country/${country.iso3}`}>
  <article class="space-y-8">
    <header class="space-y-1">
      <h1 class="text-4xl font-serif">{country.name_en}</h1>
      <p class="text-sm font-mono text-ink/60">{country.iso3} · {country.zone} · {country.currency} · {t(locale, "baseline_label")} {country.independence_year}</p>
      {country.independence_footnote_en && (
        <p class="text-xs text-ink/60 italic max-w-prose">{country.independence_footnote_en}</p>
      )}
    </header>

    <Scrubber locale={locale}
              iso3={country.iso3}
              independence_year={traj.independence_year}
              current_year={traj.current_year}
              years={traj.years} />

    <section class="space-y-3">
      <h2 class="text-2xl font-serif">Indicators</h2>
      <table class="text-sm w-full">
        <thead><tr class="text-left text-xs uppercase border-b border-ink/20">
          <th class="py-1 pr-3">id</th><th class="pr-3">indicator</th><th class="pr-3">year</th><th class="pr-3">raw</th><th class="pr-3">score</th><th>provenance</th>
        </tr></thead>
        <tbody>
          {scores.map((s) => {
            const ind = indicators.find((i) => i.id === s.indicator_id);
            const yr = s.kind === "annual" ? s.year : s.effective_year;
            return (
              <tr class="border-b border-ink/10 align-top">
                <td class="font-mono py-1 pr-3"><span class={`axis-${s.axis}`}>{s.indicator_id}</span></td>
                <td class="pr-3">{ind?.name_en}</td>
                <td class="font-mono pr-3">{yr}{s.kind==="step" && "+"}</td>
                <td class="font-mono pr-3">{String(s.raw_value)}</td>
                <td class="font-mono pr-3">{s.normalized_score}</td>
                <td class="text-xs">
                  <a class="underline" href={s.source_url} rel="noreferrer">{s.source_date}</a>
                  <br/>
                  <TagBadge tag={s.tag} type={s.type} locale={locale} />
                </td>
              </tr>
            );
          })}
        </tbody>
      </table>
      <p class="text-xs text-ink/50 font-mono">R3 + R4 + R9 stub.</p>
    </section>
  </article>
</Base>
