---
import Base from "@site/layouts/Base.astro";
import Hero from "@site/components/landing/Hero.astro";
import GapLine from "@site/components/landing/GapLine.astro";
import CommitmentCard from "@site/components/landing/CommitmentCard.astro";
import MiniTrajectory from "@site/components/landing/MiniTrajectory.astro";
import TagLegend from "@site/components/landing/TagLegend.astro";
import { t, localePath } from "@site/lib/i18n";
import { getCountries } from "@site/lib/data";

const locale = "en" as const;
const countries = getCountries();
---

<Base locale={locale} title={t(locale, "site_title")} pagePath="/">
  <Hero locale={locale} />

  <GapLine locale={locale} />

  <section class="iafs-commitments py-12 max-w-page mx-auto" aria-labelledby="commitments-title">
    <header class="space-y-2 mb-8">
      <h2 id="commitments-title" class="font-serif text-xl">{t(locale, "landing.commitments.title")}</h2>
      <p class="text-muted max-w-prose text-sm">{t(locale, "landing.commitments.subtitle")}</p>
    </header>
    <div class="grid md:grid-cols-3 gap-4">
      <CommitmentCard locale={locale}
        number={t(locale, "landing.commitments.option1.number")}
        title={t(locale, "landing.commitments.option1.title")}
        body={t(locale, "landing.commitments.option1.body")}
        href="/methodology" type="HARD" />
      <CommitmentCard locale={locale}
        number={t(locale, "landing.commitments.capture.number")}
        title={t(locale, "landing.commitments.capture.title")}
        body={t(locale, "landing.commitments.capture.body")}
        href="/methodology" type="INTERP" />
      <CommitmentCard locale={locale}
        number={t(locale, "landing.commitments.anchor.number")}
        title={t(locale, "landing.commitments.anchor.title")}
        body={t(locale, "landing.commitments.anchor.body")}
        href="/methodology" type="HARD" />
    </div>
  </section>

  <section class="iafs-miniviz py-12 max-w-page mx-auto border-t border-border" aria-labelledby="miniviz-title">
    <header class="space-y-2 mb-8">
      <h2 id="miniviz-title" class="font-serif text-xl">{t(locale, "landing.miniviz.title")}</h2>
      <p class="text-muted max-w-prose text-sm">{t(locale, "landing.miniviz.subtitle")}</p>
    </header>
    <div class="grid md:grid-cols-2 gap-4">
      {countries.map((c) => (
        <MiniTrajectory locale={locale} iso3={c.iso3} nameFR={c.name_fr} nameEN={c.name_en} />
      ))}
    </div>
  </section>

  <section class="iafs-audit py-12 max-w-page mx-auto border-t border-border" aria-labelledby="audit-title">
    <header class="space-y-2 mb-8 max-w-prose">
      <h2 id="audit-title" class="font-serif text-xl">{t(locale, "landing.audit.title")}</h2>
      <p class="text-muted text-sm">{t(locale, "landing.audit.subtitle")}</p>
      <p class="text-sm text-dim italic">{t(locale, "landing.audit.no_fabrication")}</p>
    </header>

    <div class="grid sm:grid-cols-3 gap-3 mb-12">
      <a href="https://github.com/diaspoai/afroindexsovereignty"
         class="group bg-surface border border-border p-4 rounded-md hover:border-axisA transition-colors cursor-pointer">
        <div class="font-mono text-xs uppercase tracking-widest text-dim">01</div>
        <div class="font-serif text-base mt-1 group-hover:text-axisA transition-colors">{t(locale, "landing.audit.repo_label")}</div>
      </a>
      <a href={localePath(locale, "/methodology")}
         class="group bg-surface border border-border p-4 rounded-md hover:border-axisA transition-colors cursor-pointer">
        <div class="font-mono text-xs uppercase tracking-widest text-dim">02</div>
        <div class="font-serif text-base mt-1 group-hover:text-axisA transition-colors">{t(locale, "landing.audit.method_label")}</div>
      </a>
      <a href={localePath(locale, "/events")}
         class="group bg-surface border border-border p-4 rounded-md hover:border-axisA transition-colors cursor-pointer">
        <div class="font-mono text-xs uppercase tracking-widest text-dim">03</div>
        <div class="font-serif text-base mt-1 group-hover:text-axisA transition-colors">{t(locale, "landing.audit.events_label")}</div>
      </a>
    </div>

    <TagLegend locale={locale} />
  </section>
</Base>
