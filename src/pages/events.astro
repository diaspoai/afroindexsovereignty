---
import Base from "@site/layouts/Base.astro";
import { getEvents } from "@site/lib/data";
import { t } from "@site/lib/i18n";

const locale = "fr" as const;
const events = getEvents().slice().sort((a, b) => (a.date < b.date ? 1 : -1));
---
<Base locale={locale} title={t(locale, "page.events_title")} pagePath="/events">
  <section class="space-y-6">
    <h1 class="text-3xl font-serif">{t(locale, "page.events_title")}</h1>
    <ol class="space-y-4">
      {events.map((e) => (
        <li class="border-l-4 pl-3 py-1" style={`border-color: var(--tw-color); --tw-color: ${e.axis === "A" ? "#1F3A93" : "#B8860B"};`}>
          <div class="text-xs font-mono text-ink/60">{e.date} · {e.country} · {e.axis}/{e.indicator_id} · {e.direction}</div>
          <div class="font-serif text-lg">{e.title_fr}</div>
          <div class="text-sm text-ink/80">{e.description_fr}</div>
          <a class="text-xs font-mono underline" href={e.source_url} rel="noreferrer">source · {e.source_date}</a>
        </li>
      ))}
    </ol>
    <p class="text-xs text-ink/50 font-mono">R5 stub.</p>
  </section>
</Base>
