---
import Base from "@site/layouts/Base.astro";
import { t } from "@site/lib/i18n";
const locale = "fr" as const;
---
<Base locale={locale} title={t(locale, "page.download_title")} pagePath="/download">
  <section class="space-y-6 max-w-prose mx-auto">
    <header class="space-y-2">
      <p class="font-mono text-xs uppercase tracking-[0.25em] text-accent">R7</p>
      <h1 class="font-serif text-2xl">{t(locale, "page.download_title")}</h1>
      <p class="text-muted">
        Toutes les données sous <span class="text-text font-medium">CC-BY-4.0</span>. Le dépôt est la source de vérité.
      </p>
    </header>

    <ul class="space-y-2 text-sm font-mono">
      <li>
        <a class="text-axisA hover:underline focus-visible:underline"
           href="https://github.com/diaspoai/afroindexsovereignty">
          → Dépôt GitHub
        </a>
      </li>
      <li class="text-muted"><code class="text-text">data/countries.json</code></li>
      <li class="text-muted"><code class="text-text">data/indicators.json</code></li>
      <li class="text-muted"><code class="text-text">data/methodology.json</code></li>
      <li class="text-muted"><code class="text-text">data/scores/&lt;ISO3&gt;.json</code></li>
      <li class="text-muted"><code class="text-text">data/axis_scores/&lt;ISO3&gt;.json</code></li>
      <li class="text-muted"><code class="text-text">data/events.json</code></li>
      <li class="text-muted"><code class="text-text">schemas/*.json</code> — contrat figé v0.3.0</li>
    </ul>

    <p class="text-xs text-dim font-mono">R7 stub.</p>
  </section>
</Base>
