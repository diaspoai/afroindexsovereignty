---
import Base from "@site/layouts/Base.astro";
import { getIndicators, getMethodology } from "@site/lib/data";
import { t } from "@site/lib/i18n";

const locale = "fr" as const;
const indicators = getIndicators();
const m = getMethodology();
---
<Base locale={locale} title={t(locale, "page.methodology_title")} pagePath="/methodology">
  <section class="space-y-6 max-w-prose">
    <h1 class="text-3xl font-serif">{t(locale, "page.methodology_title")}</h1>
    <p class="text-sm font-mono">version {m.version} · seuil de couverture {Math.round(m.coverage_threshold*100)}% · mode {m.mode}</p>
    <p>Voir <a href="/docs/IAFS_Requirements_v0.3.md" class="underline">le document de spécification</a>.</p>

    <h2 class="text-2xl font-serif">{t(locale, "axis_a")}</h2>
    <p class="text-ink/70">{t(locale, "axis_a_gloss")}</p>
    <table class="text-sm border-collapse">
      <thead><tr class="text-left text-xs uppercase"><th>id</th><th>indicateur</th><th>type</th><th>poids</th><th>depuis</th></tr></thead>
      <tbody>
        {indicators.filter(i => i.axis === "A").map((i) => (
          <tr class="border-t border-ink/10"><td class="font-mono pr-3">{i.id}</td><td class="pr-3">{i.name_fr}</td><td class="font-mono pr-3">{i.type}</td><td class="font-mono pr-3">×{i.weight}</td><td class="font-mono">{i.earliest_sourced_year}</td></tr>
        ))}
      </tbody>
    </table>

    <h2 class="text-2xl font-serif">{t(locale, "axis_b")}</h2>
    <p class="text-ink/70">{t(locale, "axis_b_gloss")}</p>
    <table class="text-sm border-collapse">
      <thead><tr class="text-left text-xs uppercase"><th>id</th><th>indicateur</th><th>type</th><th>poids</th><th>depuis</th></tr></thead>
      <tbody>
        {indicators.filter(i => i.axis === "B").map((i) => (
          <tr class="border-t border-ink/10"><td class="font-mono pr-3">{i.id}</td><td class="pr-3">{i.name_fr}</td><td class="font-mono pr-3">{i.type}</td><td class="font-mono pr-3">×{i.weight}</td><td class="font-mono">{i.earliest_sourced_year}</td></tr>
        ))}
      </tbody>
    </table>

    <p class="text-xs text-ink/50 font-mono">R6 stub.</p>
  </section>
</Base>
