{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://iafs/schemas/axis_score.schema.json",
  "title": "AxisScore",
  "description": "Per (country, axis, year) coverage-aware aggregate. Stored on disk (D9) AND reproducible by normalize.ts. axis_score is null when coverage < methodology.coverage_threshold — the UI then renders the year as a gap.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "country","axis","year","axis_score","coverage",
    "contributing_indicators","missing_indicators","below_coverage_threshold","is_baseline_year"
  ],
  "properties": {
    "country": { "type": "string", "pattern": "^(BEN|BFA|CIV|MLI|NER|SEN|TGO|CMR|CAF|TCD|COG|GAB|ZZ[A-Z])$" },
    "axis": { "enum": ["A","B"] },
    "year": { "type": "integer", "minimum": 1900, "maximum": 2100 },
    "axis_score": {
      "oneOf": [
        { "type": "number", "minimum": 0, "maximum": 100 },
        { "type": "null" }
      ]
    },
    "coverage": { "type": "number", "minimum": 0, "maximum": 1 },
    "contributing_indicators": {
      "type": "array",
      "items": { "enum": ["A1","A2","A3","A4","A5","A6","B1","B2","B3","B4","B5"] },
      "uniqueItems": true
    },
    "missing_indicators": {
      "type": "array",
      "items": { "enum": ["A1","A2","A3","A4","A5","A6","B1","B2","B3","B4","B5"] },
      "uniqueItems": true
    },
    "below_coverage_threshold": { "type": "boolean" },
    "is_baseline_year": { "type": "boolean" }
  }
}
